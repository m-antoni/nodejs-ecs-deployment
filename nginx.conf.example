# ============================================================
# NGINX CONFIGURATION TEMPLATE
# ============================================================
# Copy this file to nginx.conf and customize for your setup
#
# Usage:
#   cp nginx.conf.example nginx.conf
#   # Edit nginx.conf with your domain and settings
#
# ============================================================

# ---------- UPSTREAM: Load Balancing ----------
# Uncomment and add your ECS task IPs
# ============================================================
# upstream node_app {
#     server 10.0.1.10:5000;   # Task 1
#     server 10.0.1.11:5000;   # Task 2
# }

# ---------- RATE LIMITING ----------
# Adjust rate as needed (10r/s = 10 requests per second per IP)
# ============================================================
# limit_req_zone $binary_remote_addr zone=api_limit:10m rate=10r/s;

# ---------- CACHING ----------
# Adjust cache size and duration as needed
# ============================================================
# proxy_cache_path /var/cache/nginx levels=1:2 keys_zone=app_cache:10m max_size=100m inactive=60m;

# ---------- SSL CERTIFICATE ----------
# Generate self-signed cert for testing:
#   openssl req -x509 -nodes -days 365 -newkey rsa:2048 -keyout nginx.key -out nginx.crt
# ============================================================
# ssl_certificate     /etc/ssl/certs/nginx.crt;
# ssl_certificate_key /etc/ssl/private/nginx.key;

# ---------- HTTP SERVER (Redirect to HTTPS) ----------
# ============================================================
# server {
#     listen 80;
#     server_name YOUR_DOMAIN.com;
#     return 301 https://$server_name$request_uri;
# }

